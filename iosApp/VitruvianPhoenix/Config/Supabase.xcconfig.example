// Supabase Configuration
// Copy this file to Supabase.xcconfig and fill in your values
// Supabase.xcconfig is excluded from git via .gitignore
//
// Xcode reads SupabaseBase.xcconfig, which optionally includes the local
// Supabase.xcconfig file generated from this template.

SUPABASE_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = your-supabase-anon-key

// Tracked base config used by the Xcode project.
//
// Keep real Supabase values in Supabase.xcconfig. That file is ignored by git
// and generated by CI from secrets. Local builds can create it by copying
// Supabase.xcconfig.example and filling in real values.

SUPABASE_URL =
SUPABASE_ANON_KEY =

#include? "Supabase.xcconfig"

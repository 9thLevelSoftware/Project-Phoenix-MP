<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>SUPABASE_ANON_KEY</key>
	<string>$(SUPABASE_ANON_KEY)</string>
	<key>SUPABASE_URL</key>
	<string>$(SUPABASE_URL)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.devil.phoenixproject.auth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.devil.phoenixproject</string>
			</array>
		</dict>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>CFBundleDisplayName</key>
	<string>Project Phoenix</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Project Phoenix needs Bluetooth to connect to your Vitruvian Trainer machine.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>Project Phoenix needs Bluetooth to connect to your Vitruvian Trainer machine.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Project Phoenix can read your health data to avoid logging duplicate workouts.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Project Phoenix writes your completed workouts to Apple Health so they appear alongside your other fitness data.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Project Phoenix uses the microphone for safe word detection during workouts, enabling hands-free emergency stops.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Project Phoenix uses on-device speech recognition to listen for your safe word during workouts.</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>bluetooth-central</string>
	</array>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchScreenBackground</string>
		<key>UIImageName</key>
		<string>LaunchIcon</string>
	</dict>
</dict>
</plist>

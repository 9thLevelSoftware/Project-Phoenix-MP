-- Migration 20: Add per-exercise behavior overrides and performance index
-- RoutineExercise.stallDetectionEnabled / stopAtTop / repCountTiming are
-- intentionally healed outside this numbered migration. These columns were
-- released through schema/create paths before this migration existed, so
-- replaying ALTER TABLE here can crash existing installs with duplicate-column
-- errors while later-version installs may still be missing the columns.

-- Performance: index on WorkoutSession.timestamp for history queries (R-42)
CREATE INDEX IF NOT EXISTS idx_workout_session_timestamp ON WorkoutSession(timestamp);
